# Whisper backend: auto | local | openai
WHISPER_BACKEND=auto

# Whisper model size: tiny | base | small | medium | large-v2 | large-v3
WHISPER_MODEL=base

# Required for transcribe_telegram_voice tool
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# Required for OpenAI Whisper API transcription or OpenAI TTS voice replies
OPENAI_API_KEY=your-openai-api-key-here

# TTS backend: auto | kokoro | openai | macos
TTS_BACKEND=auto

# Default voice (Kokoro voice name)
TTS_VOICE=af_sky

# Kokoro FastAPI URL (if running locally via Docker)
KOKORO_BASE_URL=http://127.0.0.1:8880/v1
